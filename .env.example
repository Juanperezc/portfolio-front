# Destinatario del formulario de contacto.
# Si no se define, usa juanluisperezc1996@gmail.com.
CONTACT_TO="juanluisperezc1996@gmail.com"

# --- Envío de correo ---
# OPCIÓN A (recomendada, cero config): dejar SMTP vacío.
#   Se usa FormSubmit (gratis, sin cuenta). La PRIMERA vez que se envía el
#   formulario, FormSubmit manda un correo de activación a CONTACT_TO: hay
#   que abrir ese correo y confirmar una sola vez. Después, todo llega solo.
#
# OPCIÓN B (SMTP propio gratuito: Brevo, Gmail con app password, etc.).
#   Si se definen estas variables, se usa SMTP en lugar de FormSubmit.
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"          # true si el puerto es 465
# SMTP_USER="tu-usuario-smtp"
# SMTP_PASS="tu-clave-smtp"
# SMTP_FROM="Portfolio <no-reply@tudominio.com>"

# URL pública del sitio (para canonical, sitemap y Open Graph).
NEXT_PUBLIC_SITE_URL="https://juan-perez.me"

# --- Blog (Strapi) ---
STRAPI_URL="https://TU-PROYECTO.strapiapp.com"
STRAPI_API_TOKEN="tu-api-token-de-strapi"
# "true" para mostrar borradores (preview); vacío/"false" = solo publicados.
STRAPI_DRAFTS="false"
